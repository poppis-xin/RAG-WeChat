.ai-container {
  padding-bottom: 210rpx;
}

.ai-hero {
  background: linear-gradient(145deg, #eff6ff, #ffffff);
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.quick-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 24rpx;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.message-row {
  display: flex;
}

.message-row--assistant {
  justify-content: flex-start;
}

.message-row--user {
  justify-content: flex-end;
}

.message-bubble {
  max-width: 88%;
  border-radius: 26rpx;
  padding: 22rpx;
  box-sizing: border-box;
}

.message-bubble--assistant {
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.06);
}

.message-bubble--user {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  color: #ffffff;
}

.message-content {
  line-height: 1.8;
  white-space: pre-wrap;
}

.message-section {
  margin-top: 18rpx;
}

.message-label {
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.ref-chip {
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.ref-chip--official {
  background: #ecfeff;
  color: #0f766e;
}

.experience-card {
  background: #fff7ed;
  border-left: 6rpx solid #fb923c;
  border-radius: 14rpx;
  padding: 16rpx 18rpx;
  margin-bottom: 12rpx;
  color: #9a3412;
  line-height: 1.7;
}

.related-card {
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 18rpx;
  margin-bottom: 12rpx;
}

.related-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.ai-input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(18rpx + constant(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.ai-input {
  flex: 1;
  min-height: 76rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  padding: 0 26rpx;
}

.ai-send-btn {
  min-width: 120rpx;
  height: 76rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2563eb, #5b7cfa);
  color: #ffffff;
  font-weight: 700;
}

.ai-send-btn--disabled {
  opacity: 0.72;
}