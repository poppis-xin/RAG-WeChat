page {
  background: #f4f7f6;
  color: #0f172a;
  font-size: 28rpx;
}

.page-shell {
  min-height: 100vh;
  background: #f4f7f6;
}

.custom-nav {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  color: #ffffff;
  box-sizing: border-box;
}

.custom-nav__title {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
}

.custom-nav__bar {
  position: relative;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-nav__back {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  min-width: 88rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  padding-bottom: 156rpx;
  padding-bottom: calc(156rpx + env(safe-area-inset-bottom));
  padding-bottom: calc(156rpx + constant(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 118, 110, 0.08);
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.muted {
  color: #64748b;
}

.pill {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #ccfbf1;
  color: #0f766e;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #0f766e, #14b8a6);
  color: #ffffff;
  border-radius: 20rpx;
}

.ghost-btn {
  border-radius: 20rpx;
  color: #0f766e;
  border: 2rpx solid #0f766e;
  background: #ffffff;
}

.input {
  width: auto;
  border-radius: 20rpx;
  background: #f8fafc;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.textarea {
  width: auto;
  min-height: 220rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.flex {
  display: flex;
}

.between {
  justify-content: space-between;
  align-items: center;
}

.tag-row {
  margin-top: 14rpx;
}
